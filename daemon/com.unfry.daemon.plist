<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.unfry.daemon</string>

    <key>ProgramArguments</key>
    <array>
        <string>PYTHON_PATH_PLACEHOLDER</string>
        <string>DAEMON_PATH_PLACEHOLDER</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>HOME_PLACEHOLDER/.unfry/daemon.log</string>

    <key>StandardErrorPath</key>
    <string>HOME_PLACEHOLDER/.unfry/daemon.error.log</string>

    <key>WorkingDirectory</key>
    <string>DAEMON_DIR_PLACEHOLDER</string>
</dict>
</plist>
